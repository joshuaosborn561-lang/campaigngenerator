# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini (for conversational query interface and AI search)
GEMINI_API_KEY=your-gemini-api-key

# Prospeo (for enriching new contacts with verified emails)
# Used by /api/contacts/diff when "Also enrich" is checked.
PROSPEO_API_KEY=your-prospeo-api-key

# Anthropic (Campaign Testing Machine + /intelligence plain-English SQL)
# Used by /api/campaign-tester/briefs/:id/generate and POST /api/query
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional override (default claude-sonnet-4-5)
# AGENCY_QUERY_MODEL=claude-sonnet-4-5

# Calendly webhooks — verified meetings (POST /api/webhooks/calendly)
# Signing key(s): each Calendly webhook subscription has its own signing secret.
# Use one key, OR comma-separated CALENDLY_WEBHOOK_SIGNING_KEYS when YOUR account and a CLIENT'S
# account each have their own subscription hitting the same URL.
CALENDLY_WEBHOOK_SIGNING_KEY=your-calendly-webhook-signing-key
# CALENDLY_WEBHOOK_SIGNING_KEYS=key-for-your-org,key-for-client-org
# Local dev only — never set in production.
# CALENDLY_SKIP_SIGNATURE_VERIFY=true
# Map whose Calendly account fired the event (organization or user URI from the webhook JSON)
# to either your agency or a specific client UUID. Keys must match Calendly URIs exactly.
# CALENDLY_ACCOUNT_MAP={"https://api.calendly.com/organizations/YOUR_ORG_ID":{"type":"agency"},"https://api.calendly.com/organizations/CLIENT_ORG_ID":{"type":"client","client_id":"uuid-here"}}
# Optional: same URL, mixed invitees on ONE calendar — mark internal invitees as agency:
# CALENDLY_AGENCY_INVITEE_EMAILS=you@yourdomain.com,calendar@yourdomain.com
# CALENDLY_AGENCY_EMAIL_DOMAINS=yourdomain.com

# --- Sync clients from SalesGlider / Reply Handler (optional) ---
# Add GET /api/agency-intel/clients on the other app (see clients-external-import.ts comment block).
# Then set:
# EXTERNAL_CLIENTS_SYNC_URL=https://app-production-9354.up.railway.app/api/agency-intel/clients
# EXTERNAL_CLIENTS_SYNC_BEARER_TOKEN=same-secret-as-AGENCY_INTEL_SYNC_SECRET-on-reply-handler
# Optional: protect POST /api/clients/sync-external on THIS app (cron curl):
# CLIENTS_SYNC_SECRET=random-long-string
