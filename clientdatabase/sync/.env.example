# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Service role JWT: Dashboard → API → legacy service_role, or:
#   export SUPABASE_ACCESS_TOKEN=...  # supabase.com/dashboard/account/tokens
#   ../scripts/fetch-supabase-service-role.sh
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini (for AI classification during ingestion)
GEMINI_API_KEY=your-gemini-api-key

# SmartLead and HeyReach API keys are stored per-client in the clients table (encrypted).
#
# For a **single agency account** that should pull every campaign on that SmartLead/HeyReach
# workspace, set **account-level** keys here (Railway on `agency-intel-sync`). They override
# DB keys for sync only — use your main account / API keys from each vendor dashboard.
#   SMARTLEAD_ACCOUNT_API_KEY=...   (or alias SMARTLEAD_API_KEY)
#   HEYREACH_ACCOUNT_API_KEY=...    (or alias HEYREACH_API_KEY)
#
# If unset, sync uses each client's keys from `set_client_api_keys` (multi-tenant).
#
# SmartLead agency/white-label: the GET /campaigns/ list is scoped to a sub-workspace; set the
# numeric `client_id` from SmartLead so the API returns campaigns. Example:
#   SMARTLEAD_CLIENT_ID=123456

# Optional: log Gemini ICP/offer inference without writing to the database
# INFERENCE_DRY_RUN=false
