# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Service role JWT: Dashboard → API → legacy service_role, or:
#   export SUPABASE_ACCESS_TOKEN=...  # supabase.com/dashboard/account/tokens
#   ../scripts/fetch-supabase-service-role.sh
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini (for AI classification during ingestion)
GEMINI_API_KEY=your-gemini-api-key

# SmartLead and HeyReach API keys are stored per-client in the clients table.
# You do NOT need global keys for either platform here.

# Optional: log Gemini ICP/offer inference without writing to the database
# INFERENCE_DRY_RUN=false
